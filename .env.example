TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_APP_URL=https://t.me/your_bot_username/your_app_short_name
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,https://your-mini-app-domain.example

# Local Docker Compose PostgreSQL settings.
POSTGRES_DB=football_app
POSTGRES_USER=football_user
POSTGRES_PASSWORD=change-me-before-production

# Backend service settings for non-Compose deployments such as Railway.
DB_URL=jdbc:postgresql://your-postgres-host:5432/football_app
DB_USERNAME=football_user
DB_PASSWORD=change-me-before-production
